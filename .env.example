PORT=5000
JWT_SECRET=change_this_to_a_long_random_secret_in_production
CLIENT_URL=http://localhost:5173
DATABASE_URL=postgresql://localhost:5432/pettracker

# PLACEHOLDER: Cloud storage (e.g. AWS S3, Firebase Storage, Cloudinary)
# Replace local ./uploads folder with signed upload URLs from your chosen provider
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=pet-tracker-uploads

# PLACEHOLDER: Push notification service (e.g. Firebase Cloud Messaging)
# Used for sending meal/exercise reminders to mobile clients
# FCM_SERVER_KEY=

# PLACEHOLDER: Email service (e.g. SendGrid, Mailgun, Resend)
# SENDGRID_API_KEY=
# EMAIL_FROM=noreply@yourapp.com
